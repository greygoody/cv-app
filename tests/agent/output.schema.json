{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cv-app local Codex acceptance report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "skill_used",
    "candidate_id",
    "focus_id",
    "source_files_read",
    "closure_state",
    "selected_model_id",
    "rejected_model_ids",
    "retained_unknown_ids",
    "prohibited_inference_ids",
    "closure_file",
    "closure_written",
    "canonical_mutation_performed",
    "summary"
  ],
  "properties": {
    "status": { "type": "string", "enum": ["passed"] },
    "skill_used": { "type": "string", "enum": ["grind-with-doc"] },
    "candidate_id": { "type": "string", "enum": ["candidate.morgan-vale"] },
    "focus_id": {
      "type": "string",
      "enum": ["focus.technical-lead-vs-integration-owner"]
    },
    "source_files_read": {
      "type": "array",
      "items": { "type": "string", "enum": ["source.md"] },
      "minItems": 1,
      "maxItems": 1
    },
    "closure_state": { "type": "string", "enum": ["resolved-proposed"] },
    "selected_model_id": {
      "type": "string",
      "enum": ["installation-integration-owner-operational-handoff"]
    },
    "rejected_model_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "whole-exhibition-technical-lead",
          "documentation-only-technician"
        ]
      },
      "minItems": 2,
      "maxItems": 2
    },
    "retained_unknown_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "post-installation-ownership-duration",
          "measured-reliability-or-recovery-effect"
        ]
      },
      "minItems": 2,
      "maxItems": 2
    },
    "prohibited_inference_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "formal-project-wide-leadership",
          "people-management",
          "budget-or-creative-authority",
          "quantified-reliability-impact"
        ]
      },
      "minItems": 4,
      "maxItems": 4
    },
    "closure_file": { "type": "string", "enum": ["session-closure.md"] },
    "closure_written": { "type": "boolean" },
    "canonical_mutation_performed": { "type": "boolean" },
    "summary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 800
    }
  }
}
